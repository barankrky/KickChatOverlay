<Window x:Class="KickChatOverlay.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:loc="clr-namespace:KickChatOverlay.Extensions"
        Title="{loc:Loc SettingsWindowTitle}"
        Width="420" Height="620"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#1E1E2E"
        Foreground="White">

    <Window.Resources>
        <Style x:Key="DarkComboBoxItem" TargetType="ComboBoxItem">
            <Setter Property="Background" Value="#2A2A3E"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter Property="Background" Value="#9147FF"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#9147FF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="20">
        <StackPanel>
            <TextBlock Text="{loc:Loc SettingsHeader}" FontSize="18"
                       FontWeight="Bold" Margin="0,0,0,16"/>

            <!-- Botrix Bot ID -->
            <TextBlock Text="{loc:Loc SectionBotrix}" FontSize="11" Foreground="#888"
                       Margin="0,0,0,4"/>
            <TextBlock Text="{loc:Loc LabelBotrixId}" Margin="0,0,0,4"/>
            <TextBox Text="{Binding Settings.BotrixBotId, UpdateSourceTrigger=PropertyChanged}"
                     Padding="6" Margin="0,0,0,2"
                     Background="#2A2A3E" Foreground="White" BorderBrush="#444"/>
            <TextBlock Text="{loc:Loc HintBotrixId}" FontSize="10" Foreground="#888"
                       Margin="0,0,0,12" TextWrapping="Wrap"/>



            <Separator Background="#333" Margin="0,0,0,12"/>

            <!-- Widget Appearance -->
            <TextBlock Text="{loc:Loc SectionWidget}" FontSize="11" Foreground="#888"
                       Margin="0,0,0,8"/>

            <StackPanel Margin="0,0,0,12">
                <CheckBox Content="{loc:Loc CheckPlatformIcon}"
                          IsChecked="{Binding Settings.BotrixShowPlatformIcon}"
                          Foreground="White" Margin="0,0,0,4"/>
                <CheckBox Content="{loc:Loc CheckBots}"
                          IsChecked="{Binding Settings.BotrixShowBots}"
                          Foreground="White" Margin="0,0,0,4"/>
                <CheckBox Content="{loc:Loc CheckEmojis}"
                          IsChecked="{Binding Settings.BotrixShowEmojis}"
                          Foreground="White" Margin="0,0,0,4"/>
                <CheckBox Content="{loc:Loc CheckHideCommands}"
                          IsChecked="{Binding Settings.BotrixHideCommands}"
                          Foreground="White" Margin="0,0,0,4"/>
                <CheckBox Content="{loc:Loc CheckTimestamp}"
                          IsChecked="{Binding Settings.BotrixShowTimestamp}"
                          Foreground="White" Margin="0,0,0,4"/>
                <CheckBox Content="{loc:Loc CheckCheer}"
                          IsChecked="{Binding Settings.BotrixCheer}"
                          Foreground="White" Margin="0,0,0,4"/>
                <CheckBox Content="{loc:Loc CheckPointsReward}"
                          IsChecked="{Binding Settings.BotrixPointsReward}"
                          Foreground="White" Margin="0,0,0,4"/>
                <CheckBox Content="{loc:Loc CheckStreamTogether}"
                          IsChecked="{Binding Settings.BotrixStreamTogether}"
                          Foreground="White" Margin="0,0,0,8"/>
            </StackPanel>

            <TextBlock Margin="0,0,0,4">
                <Run Text="{loc:Loc LabelWidgetSize}" />
                <Run Text="{Binding Settings.BotrixWidgetSize, StringFormat=' {0}'}" />
            </TextBlock>
            <Slider Value="{Binding Settings.BotrixWidgetSize}" Minimum="10" Maximum="48"
                    TickFrequency="1" IsSnapToTickEnabled="True" Margin="0,0,0,8"/>

            <TextBlock Margin="0,0,0,4">
                <Run Text="{loc:Loc LabelHideMessages}" />
                <Run Text="{Binding Settings.BotrixHideMessagesSeconds, StringFormat=' {0}'}" />
            </TextBlock>
            <Slider Value="{Binding Settings.BotrixHideMessagesSeconds}" Minimum="3" Maximum="60"
                    TickFrequency="1" IsSnapToTickEnabled="True" Margin="0,0,0,8"/>

            <TextBlock Margin="0,0,0,4">
                <Run Text="{loc:Loc LabelShadowThickness}" />
                <Run Text="{Binding Settings.BotrixShadowThickness, StringFormat=' {0}'}" />
            </TextBlock>
            <Slider Value="{Binding Settings.BotrixShadowThickness}" Minimum="0" Maximum="3"
                    TickFrequency="1" IsSnapToTickEnabled="True" Margin="0,0,0,12"/>

            <Button Content="{loc:Loc ButtonSaveClose}" Click="SaveClose_Click"
                    Padding="16,8" Background="#53FC18" Foreground="#111"
                    BorderThickness="0" Cursor="Hand" HorizontalAlignment="Right"/>
        </StackPanel>
    </ScrollViewer>
</Window>
