<Window x:Class="KickChatOverlay.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:services="clr-namespace:KickChatOverlay.Services"
        xmlns:loc="clr-namespace:KickChatOverlay.Extensions"
        Title="{loc:Loc SettingsWindowTitle}"
        Width="400" Height="560"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#1E1E2E"
        Foreground="White">

    <Window.Resources>
        <!-- Dark-themed ComboBox dropdown item style -->
        <Style x:Key="DarkComboBoxItem" TargetType="ComboBoxItem">
            <Setter Property="Background" Value="#2A2A3E"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter Property="Background" Value="#9147FF"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#9147FF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="20">
        <StackPanel>
            <TextBlock Text="{loc:Loc SettingsHeader}" FontSize="18"
                       FontWeight="Bold" Margin="0,0,0,16"/>

            <!-- Connection -->
            <TextBlock Text="{loc:Loc SectionChannel}" FontSize="11" Foreground="#888"
                       Margin="0,0,0,4"/>
            <TextBlock Text="{loc:Loc LabelKickUsername}" Margin="0,0,0,4"/>
            <TextBox Text="{Binding Settings.KickUsername, UpdateSourceTrigger=PropertyChanged}"
                     Padding="6" Margin="0,0,0,8"
                     Background="#2A2A3E" Foreground="White" BorderBrush="#444"/>

            <TextBlock Text="{loc:Loc LabelChatroomId}"
                       Margin="0,0,0,4" FontSize="11" Foreground="#888"/>
            <TextBox Text="{Binding Settings.KickChatroomId, UpdateSourceTrigger=PropertyChanged}"
                     Padding="6" Margin="0,0,0,12"
                     Background="#2A2A3E" Foreground="White" BorderBrush="#444"/>

            <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                <Button Content="{loc:Loc ButtonConnect}" Command="{Binding ConnectCommand}"
                        Padding="16,6" Background="#53FC18" Foreground="#111"
                        BorderThickness="0" Cursor="Hand" Margin="0,0,8,0"/>
                <Button Content="{loc:Loc ButtonDisconnect}" Command="{Binding DisconnectCommand}"
                        Padding="16,6" Background="#444" Foreground="White"
                        BorderThickness="0" Cursor="Hand"/>
            </StackPanel>

            <Separator Background="#333" Margin="0,0,0,12"/>

            <!-- Appearance -->
            <TextBlock Text="{loc:Loc SectionAppearance}" FontSize="11" Foreground="#888"
                       Margin="0,0,0,8"/>

            <TextBlock Margin="0,0,0,4">
                <Run Text="{loc:Loc LabelFontSize}" />
                <Run Text="{Binding Settings.FontSize, StringFormat=' {0:F0}'}" />
            </TextBlock>
            <Slider Value="{Binding Settings.FontSize}" Minimum="10" Maximum="72"
                    TickFrequency="1" IsSnapToTickEnabled="True" Margin="0,0,0,12"/>

            <TextBlock Margin="0,0,0,4">
                <Run Text="{loc:Loc LabelOpacity}" />
                <Run Text="{Binding Settings.Opacity, StringFormat=' {0:P0}'}" />
            </TextBlock>
            <Slider Value="{Binding Settings.Opacity}" Minimum="0.1" Maximum="1.0"
                    TickFrequency="0.05" IsSnapToTickEnabled="True" Margin="0,0,0,12"/>

            <TextBlock Margin="0,0,0,4">
                <Run Text="{loc:Loc LabelMaxMessages}" />
                <Run Text="{Binding Settings.MaxMessages, StringFormat=' {0}'}" />
            </TextBlock>
            <Slider Value="{Binding Settings.MaxMessages}" Minimum="50" Maximum="500"
                    TickFrequency="50" IsSnapToTickEnabled="True" Margin="0,0,0,12"/>

            <Separator Background="#333" Margin="0,0,0,12"/>

            <!-- Toggles -->
            <TextBlock Text="{loc:Loc SectionDisplay}" FontSize="11" Foreground="#888"
                       Margin="0,0,0,8"/>
            <CheckBox Content="{loc:Loc CheckShowPlatformIcon}"
                      IsChecked="{Binding Settings.ShowPlatformIcon}"
                      Foreground="White" Margin="0,0,0,6"/>
            <CheckBox Content="{loc:Loc CheckShowBadges}"
                      IsChecked="{Binding Settings.ShowBadges}"
                      Foreground="White" Margin="0,0,0,6"/>
            <CheckBox Content="{loc:Loc CheckShowEmotes}"
                      IsChecked="{Binding Settings.ShowEmotes}"
                      Foreground="White" Margin="0,0,0,12"/>

            <Separator Background="#333" Margin="0,0,0,12"/>

            <!-- Sound -->
            <TextBlock Text="{loc:Loc SectionNotifications}" FontSize="11" Foreground="#888"
                       Margin="0,0,0,8"/>

            <TextBlock Text="{loc:Loc LabelNotificationSound}" Margin="0,0,0,4"/>
            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                <ComboBox x:Name="SoundComboBox"
                          ItemsSource="{x:Static services:SoundService.AvailableSounds}"
                          SelectedItem="{Binding Settings.NotificationSound}"
                          ItemContainerStyle="{StaticResource DarkComboBoxItem}"
                          Padding="6" Width="200"
                          Background="#2A2A3E" Foreground="White" BorderBrush="#444">
                    <ComboBox.Resources>
                        <SolidColorBrush x:Key="{x:Static SystemColors.WindowBrushKey}" Color="#2A2A3E"/>
                    </ComboBox.Resources>
                </ComboBox>
                <Button Content="{loc:Loc ButtonPreview}" Click="PreviewSound_Click"
                        Padding="10,6" Margin="8,0,0,0"
                        Background="#444" Foreground="White"
                        BorderThickness="0" Cursor="Hand"/>
            </StackPanel>

            <TextBlock Margin="0,0,0,4">
                <Run Text="{loc:Loc LabelVolume}" />
                <Run Text="{Binding Settings.NotificationVolume, StringFormat=' {0:P0}'}" />
            </TextBlock>
            <Slider Value="{Binding Settings.NotificationVolume}" Minimum="0" Maximum="1.0"
                    TickFrequency="0.1" IsSnapToTickEnabled="True" Margin="0,0,0,12"/>

            <Separator Background="#333" Margin="0,0,0,12"/>

            <Button Content="{loc:Loc ButtonSaveClose}" Click="SaveClose_Click"
                    Padding="16,8" Background="#53FC18" Foreground="#111"
                    BorderThickness="0" Cursor="Hand" HorizontalAlignment="Right"/>
        </StackPanel>
    </ScrollViewer>
</Window>
